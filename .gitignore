# -------------------------
# Büyük model ağırlıkları ve türevleri
# (Metin tabanlı küçük konfig/dokümanları tutmak istiyoruz.)
# -------------------------
# Varsayılan: models altını ignore et
models/**

# İSTİSNALAR: metin tabanlı küçük dosyaları takip et
!models/
!models/**/
!models/**/README.md
!models/**/config.json
!models/**/generation_config.json
!models/**/processor_config.json
